def fetch(repo, remote_name='origin'):
    remote = repo.remotes[remote_name]
    remote.fetch()

def merge(repo, remote_name='origin', branch='master'):
    """
    Performs a git pull equivalent: fetches the remote and updates the local branch.

    Args:
        repo: pygit2.Repository instance
        remote_name: Name of the remote (e.g., 'origin')
        branch: Name of the branch to pull (e.g., 'master')
    """

    # 1. Get the remote tracking branch reference
    remote_branch_name = f'refs/remotes/{remote_name}/{branch}'
    remote_commit_id = repo.lookup_reference(remote_branch_name).target
    remote_commit = repo.get(remote_commit_id)

    # 2. Analyze if and how we can merge
    merge_result, _ = repo.merge_analysis(remote_commit_id)

    # 3. Case 1: Already up to date
    if merge_result & GIT_MERGE_ANALYSIS_UP_TO_DATE:
        print("Already up to date.")
        return

    # 4. Case 2: Fast-forward possible
    elif merge_result & GIT_MERGE_ANALYSIS_FASTFORWARD:
        print("Fast-forwarding...")
        # Move the branch reference and HEAD to the remote commit
        repo.checkout_tree(remote_commit)
        branch_ref = repo.lookup_reference(f'refs/heads/{branch}')
        branch_ref.set_target(remote_commit_id)
        repo.head.set_target(remote_commit_id)
        #print(f"Updated to {remote_commit_id.hex}")

    # 5. Case 3: True merge required
    elif merge_result & GIT_MERGE_ANALYSIS_NORMAL:
        print("Merging...")
        # Perform the merge
        repo.merge(remote_commit_id)

        # Check for conflicts
        if repo.index.conflicts:
            print("Conflicts detected! Please resolve them manually.")
            # You can iterate through conflicts if needed:
            # for conflict in repo.index.conflicts:
            #     print(f"Conflict in: {conflict[0].path}")
            return

        # No conflicts: commit the merge
        user = repo.default_signature
        tree = repo.index.write_tree()
        repo.create_commit(
            'HEAD',
            user,
            user,
            f"Merge remote branch '{remote_name}/{branch}'",
            tree,
            [repo.head.target, remote_commit_id]
        )
        # Clean up merge state
        repo.state_cleanup()
        print("Merge completed successfully.")

    else:
        raise RuntimeError("Unknown merge analysis result")

class Log:
    def __init__(self):
        pass

    def err(self, fmt, *arg):
        print(f"{pgname}: " + fmt % arg, file=sys.stderr)
        return 1

    def info(self, fmt, *arg):
        print(f"{pgname}: " + fmt % arg)
        return 0

    def debug(self, fmt, *arg):
        print(f"{pgname}: " + fmt % arg)
        return 0

class Help(Log):
    def __init__(self):
        pass

    def cmd_exists(self, cmd):
        if help_cmds.get(cmd) == None:
            return False
        return True

    def show_help(self, cmd):
        head = help_cmds[cmd]['head']
        body = help_cmds[cmd]['body']
        synop = help_cmds[cmd]['synop']
        print(synop)
        print("   ", head)
        print(body, end='')

    def show_list(self):
        for cmd in help_cmds:
            print(f"{cmd}\t{self.get_head(cmd)}")

    def get_head(self, cmd):
        if self.cmd_exists(cmd) == False:
            return None
        return help_cmds[cmd]['head']

    def get_body(self, cmd):
        if self.cmd_exists(cmd) == False:
            return None
        return help_cmds[cmd]['body']

class Config:
    def __init__(self):
        self.config = None

    def _get_config_file(self):
        paths = [
            "/".join([os.environ["HOME"], ".tec/pgn/nine.json"]),
            "/".join([os.environ["HOME"], ".config/tec/pgn/nine.json"]),
        ]
        for cfg in paths:
            if os.path.exists(cfg):
                return cfg
        return None

    def _get_defaults(self):
        return {}

    def get(self):
        fname = self._get_config_file()

        if fname == None:
            self.err("no config file is found")
            sys.exit(1)
        with open(fname) as file:
            self.config = json.load(file)
        return self.config

class Repo:
    def __init__(self, config, path):
        self.config = config
        self.path = path

    def setup(self):
        pass

    def pull(self):
        pass

    def fetch(self, remote_name="origin"):
        for cfg in self.config['repos']:
            repo = pygit2.Repository(self.path + '/' + cfg['name'])
            fetch(repo)
        return True

    def merge(self, remote_name="origin"):
        for cfg in self.config['repos']:
            repo = pygit2.Repository(self.path + '/' + cfg['name'])
            #print("->>", cfg['name'])
            merge(repo, 'origin', cfg['branch'])
        return True

class Nine:
    def __init__(self, pgnbase):
        self.log = Log()
        self.pgnbase = pgnbase
        self.config = Config().get()
        self.settings = Config().get()

    def _get_desc(self, pgn):
        desc = "Tec plugin"
        fname = "/".join([self.pgnbase, pgn, "desc"])

        if os.path.isfile(fname):
            with open(fname, "r") as f:
                desc = f.readline()
                if desc:
                    desc = desc.strip("\n")
        return desc


    def add(self): # Activate plugin
        pass

    def cfg(self): # config show, edit, list, get, set
        for _cfg in self.config["repos"]:
            print(f"{_cfg["name"]}\t{_cfg["link"]}")

    def help(self):
        help = Help()

        if len(args.args) == 0:
            return help.show_list()

        for cmd in args.args:
            if help.cmd_exists(cmd) == False:
                self.log.err("'%s': no such plugin command", cmd)
                continue
            help.show_help(cmd)
            #print(f"{cmd}\t{help.get_head(cmd)}")

    def init(self): # Download plugins
        for cfg in self.config["repos"]:
            repodir = "/".join([self.pgnbase, cfg['name']])
            if not os.path.exists(repodir):
                pygit2.clone_repository(cfg['link'], repodir)

    def rm(self): # Deactiate plugin
        pass

    def show(self):
        path = Path(self.pgnbase)
        plugins = [entry.name for entry in path.iterdir() if entry.is_dir()]

        for pgn in plugins:
            print(f"{pgn}\t{self._get_desc(pgn)}")

    def sync(self): # Git pull
        repo = Repo(self.settings, args.pgnbase)
        repo.fetch()
        repo.merge()

    def version(self):
        print(f"{pgname}: {pgnver}")

parser = argparse.ArgumentParser(description="Tec plugin manager")
parser.add_argument("-P", "--pgnbase", help="pgn directory base")
parser.add_argument("-T", "--taskbase", help="task directory base")
parser.add_argument("-V", "--version", action="store_true", help="plugin version")
parser.add_argument("cmd", default=default_cmd, nargs='?', type=str, help="subcommand")
parser.add_argument("args", type=str, nargs='*', help="non-positional arguments")
args = parser.parse_args()

def main():
    log = Log()
    nine = Nine(args.pgnbase)
    cmd = getattr(nine, args.cmd, None)

    if args.version:
        cmd = getattr(nine, "version", None)

    if cmd is not None:
        res = cmd()
    else:
        res = log.err(f"'{args.cmd}': no such command")
    sys.exit(res)

main()
